# Frontend
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_APP_NAME=AI Video Editor
NEXT_PUBLIC_MAX_FILE_SIZE=5368709120
NEXT_PUBLIC_SUPPORTED_FORMATS=mp4,mov,avi,mkv,webm

# Backend
NODE_ENV=development
PORT=5000
API_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://postgres:postgres@db:5432/ai_video_editor
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ai_video_editor
DB_USER=postgres
DB_PASSWORD=postgres
DB_POOL_SIZE=20

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRY=7d
REFRESH_TOKEN_EXPIRY=30d
BCRYPT_ROUNDS=10

# File Upload
MAX_FILE_SIZE=5368709120
UPLOAD_DIR=/app/uploads
TEMP_DIR=/app/temp
PROCESSED_DIR=/app/processed
FILE_RETENTION_DAYS=7

# FFmpeg
FFMPEG_PATH=/usr/bin/ffmpeg
FFPROBE_PATH=/usr/bin/ffprobe
FFMPEG_TIMEOUT=3600

# Processing
MAX_WORKERS=4
JOB_TIMEOUT=3600
KEEP_TEMP_FILES=false
GPU_ACCELERATION=true

# Redis
REDIS_URL=redis://redis:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# AI Models
TENSORFLOW_GPU=true
MODEL_PATH=/app/models
LOGO_DETECTION_MODEL=logo-detector
WATERMARK_DETECTION_MODEL=watermark-detector

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=10
RATE_LIMIT_ENABLED=true

# Security
CORS_ORIGIN=http://localhost:3000
ALLOWED_ORIGINS=localhost:3000,localhost:5000
SECURE_COOKIES=false
SAMESITE_COOKIES=Lax

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json

# Email (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@ai-video-editor.com

# AWS S3 (Optional - for cloud storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=
AWS_S3_ENDPOINT=

# Sentry (Error tracking)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# Feature Flags
ENABLE_AI_INPAINTING=true
ENABLE_BATCH_PROCESSING=true
ENABLE_GPU_PROCESSING=true
