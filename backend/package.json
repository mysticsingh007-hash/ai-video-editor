{
  "name": "ai-video-editor-backend",
  "version": "1.0.0",
  "description": "Express.js backend for AI video editor",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "migrate": "node dist/database/migrations.js",
    "seed": "node dist/database/seed.js",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "express": "^4.18.2",
    "express-cors": "^1.0.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "pg": "^8.11.1",
    "redis": "^4.6.10",
    "bull": "^4.11.4",
    "jsonwebtoken": "^9.1.0",
    "bcryptjs": "^2.4.3",
    "multer": "^1.4.5-lts.1",
    "fluent-ffmpeg": "^2.1.2",
    "opencv4nodejs": "^5.10.0",
    "axios": "^1.6.0",
    "uuid": "^9.0.0",
    "winston": "^3.11.0",
    "express-rate-limit": "^7.0.0",
    "helmet": "^7.1.0",
    "joi": "^17.11.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.20",
    "@types/node": "^20.9.0",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/bcryptjs": "^2.4.4",
    "@types/uuid": "^9.0.6",
    "typescript": "^5.3.0",
    "ts-node": "^10.9.1",
    "nodemon": "^3.0.1",
    "eslint": "^8.52.0",
    "@typescript-eslint/eslint-plugin": "^6.10.0",
    "@typescript-eslint/parser": "^6.10.0"
  }
}
